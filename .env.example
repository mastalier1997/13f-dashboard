# --- Frontend (Vite reads these from .env.local; anon key only) ---
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# --- Ingestion job (GitHub Actions secrets; service_role key, never in the frontend) ---
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key
# SEC requires a descriptive User-Agent or it blocks you:
SEC_USER_AGENT=13f-dashboard your-email@example.com
